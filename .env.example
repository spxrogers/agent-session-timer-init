# ─────────────────────────────────────────────────────────────────────────────
# Provider selection
# ─────────────────────────────────────────────────────────────────────────────
# Which provider to ping. Start with anthropic. (anthropic | openai)
PING_PROVIDER=anthropic

# Optional overrides. Leave PING_MODEL unset to use the provider's cheapest
# default (Anthropic: claude-haiku-4-5).
# PING_MODEL=claude-haiku-4-5
PING_MESSAGE=hello 👋
PING_MAX_TOKENS=16

# Set to 1 to never send a real request (useful for smoke tests).
# PING_DRY_RUN=0

# ─────────────────────────────────────────────────────────────────────────────
# Anthropic credentials — pick ONE mode
# ─────────────────────────────────────────────────────────────────────────────
# RECOMMENDED for the "never idle" goal: a Claude subscription OAuth token.
# This authenticates as your Claude plan and consumes/starts your usage window
# (the "bucket" you want to keep warm). Create a long-lived token with:
#   claude setup-token
CLAUDE_CODE_OAUTH_TOKEN=

# ALTERNATIVE: a standard API key (pay-per-token, billed separately from your
# subscription — a health check, but it does NOT touch your subscription buckets).
# ANTHROPIC_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# OpenAI / Codex (only if PING_PROVIDER=openai; run `npm install openai` first)
# ─────────────────────────────────────────────────────────────────────────────
# OPENAI_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Cron endpoint protection (production)
# ─────────────────────────────────────────────────────────────────────────────
# When set, /api/cron requires "Authorization: Bearer <CRON_SECRET>".
# Vercel Cron sends this header automatically when CRON_SECRET is configured.
CRON_SECRET=

# Optional: purely cosmetic, shown on the status page.
# CRON_SCHEDULE_DISPLAY=every 4 hours (0 */4 * * *)
